{
  "name": "trakt",
  "description": "Track what you're watching — search movies and shows, check in, browse your history, manage your watchlist, and get recommendations.",
  "version": "1.0.0",
  "author": {
    "name": "kud",
    "url": "https://github.com/kud"
  },
  "homepage": "https://github.com/kud/mcp-trakt",
  "license": "MIT",
  "mcpServers": {
    "mcp-trakt": {
      "command": "npx",
      "args": ["-y", "@kud/mcp-trakt@latest"],
      "env": {
        "TRAKT_CLIENT_ID": "${MCP_TRAKT_CLIENT_ID}",
        "TRAKT_ACCESS_TOKEN": "${MCP_TRAKT_ACCESS_TOKEN}"
      }
    }
  }
}
